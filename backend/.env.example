# ═══════════════════════════════════════════════════════
# ZipZapZoi Eats — Production Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this to .env and fill in your values.
# NEVER commit .env to version control!

# ─── DATABASE ────────────────────────────────────────────
# Local:    postgresql://postgres:PASSWORD@localhost:5432/zipzapzoi?schema=public
# Cloud:    postgresql://user:pass@host:5432/zipzapzoi?schema=public (Supabase, Railway, Neon)
DATABASE_URL="postgresql://postgres@localhost:5432/zipzapzoi?schema=public"

# ─── AUTHENTICATION ──────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_BYTE_HEX_STRING
# Set to false for production (disables console logging, enforces real auth)
DEMO_MODE=false

# ─── RAZORPAY ────────────────────────────────────────────
# Test keys: rzp_test_xxx / test_secret_xxx (sandbox payments)
# Live keys: rzp_live_xxx / live_secret_xxx (real payments — requires KYC)
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_YourTestKeyId
RAZORPAY_KEY_SECRET=YourTestKeySecret123

# ─── GOOGLE OAUTH ────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# ─── CLOUDINARY (Media Uploads) ──────────────────────────
# Get from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WEB PUSH (VAPID Keys) ──────────────────────────────
# Generate with: npx web-push generate-vapid-keys
PUBLIC_VAPID_KEY=YOUR_PUBLIC_VAPID_KEY
PRIVATE_VAPID_KEY=YOUR_PRIVATE_VAPID_KEY

# ─── EMAIL / SMTP ───────────────────────────────────────
# Leave blank = Ethereal test emails (dev mode, preview URLs in console)
# For production, use SendGrid, Mailgun, Gmail App Password, or AWS SES
# SendGrid: host=smtp.sendgrid.net, port=587, user=apikey, pass=SG.xxx
# Gmail:    host=smtp.gmail.com,    port=587, user=you@gmail.com, pass=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SMTP_FROM="ZipZapZoi Eats" <noreply@zipzapzoi.in>

# ─── SMS (Twilio - Optional) ────────────────────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# ─── SERVER ──────────────────────────────────────────────
PORT=5000
# Add your production domain here
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:5500,https://zipzapzoi.in,https://zipzapzoi.com
NODE_ENV=production
