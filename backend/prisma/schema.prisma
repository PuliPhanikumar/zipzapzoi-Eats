generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int                @id @default(autoincrement())
  zoiId             String             @unique
  name              String
  email             String?            @unique
  phone             String?
  role              String             @default("Customer")
  passwordHash      String?
  avatar            String?
  status            String             @default("Active")
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  referralCode      String?            @unique
  referredById      Int?
  zipPoints         Int                @default(0)
  addresses         Address[]
  disputes          Dispute[]
  favorites         Favorite[]
  feedbacks         Feedback[]
  notifications     Notification[]
  orders            Order[]
  orderRatings      OrderRating[]
  pushSubscriptions PushSubscription[]
  referralRewards   ReferralReward[]   @relation("ReferrerRewards")
  supportTickets    SupportTicket[]
  referredBy        User?              @relation("ReferralChain", fields: [referredById], references: [id])
  referrals         User[]             @relation("ReferralChain")
  userBadges        UserBadge[]
  subscriptions     UserSubscription[]

  @@index([role])
  @@index([status])
  @@index([referralCode])
  @@index([referredById])
}

model Restaurant {
  id           Int               @id @default(autoincrement())
  zoiId        String            @unique
  name         String
  ownerName    String?
  ownerEmail   String?
  phone        String?
  address      String?
  image        String?
  tags         String[]          @default([])
  status       String            @default("Pending")
  rating       Float             @default(0.0)
  revenue      Float             @default(0.0)
  plan         String?
  isPosOnly    Boolean           @default(false)
  zone         String?
  deliveryTime String?           @default("30 min")
  costForTwo   String?
  promoted     Boolean           @default(false)
  offer        String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  inventory    InventoryItem[]
  menus        Menu[]
  orders       Order[]
  staff        RestaurantStaff[]
  reviews      Review[]
  tables       Table[]

  @@index([status])
  @@index([zone])
}

model Menu {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  itemName     String
  price        Float
  description  String?
  image        String?
  category     String
  type         String?
  isAvailable  Boolean    @default(true)
  isBestseller Boolean    @default(false)
  nutrition    Json?
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
  @@index([category])
}

model Order {
  id                Int        @id @default(autoincrement())
  zoiId             String     @unique
  userId            Int?
  restaurantId      Int
  total             Float
  status            String     @default("Pending")
  type              String     @default("Delivery")
  items             String?
  deliveryAddress   String?
  zone              String?
  riderId           Int?
  paymentMethod     String?
  paymentStatus     String     @default("Pending")
  razorpayOrderId   String?
  razorpayPaymentId String?
  tracking          Json?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  tableId           String?
  restaurant        Restaurant @relation(fields: [restaurantId], references: [id])
  user              User?      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([restaurantId])
  @@index([riderId])
  @@index([status])
  @@index([zone])
  @@index([tableId])
}

model Table {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  tableNumber  String
  capacity     Int
  status       String     @default("Available")
  qrCode       String?    @unique
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([restaurantId, tableNumber])
  @@index([restaurantId])
  @@index([status])
}

model Zone {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  lat             Float
  lng             Float
  radius          Int      @default(5000)
  isActive        Boolean  @default(true)
  surgeMultiplier Float    @default(1.0)
  createdAt       DateTime @default(now())
}

model Wallet {
  id           Int           @id @default(autoincrement())
  entityId     String        @unique
  entityType   String
  balance      Float         @default(0.0)
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id          Int      @id @default(autoincrement())
  walletId    Int
  type        String
  amount      Float
  description String
  orderId     Int?
  createdAt   DateTime @default(now())
  wallet      Wallet   @relation(fields: [walletId], references: [id])

  @@index([walletId])
}

model Feedback {
  id         Int      @id @default(autoincrement())
  userId     Int?
  category   String   @default("General")
  subject    String?
  message    String
  rating     Int      @default(5)
  status     String   @default("Open")
  priority   String   @default("Medium")
  assignedTo String?
  responses  Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User?    @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model Review {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  authorName   String
  authorEmail  String?
  rating       Int        @default(5)
  title        String?
  text         String?
  helpful      Int        @default(0)
  photos       String[]   @default([])
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model Dispute {
  id          Int      @id @default(autoincrement())
  ticketId    String   @unique
  userId      Int?
  orderId     String?
  title       String
  description String?
  type        String   @default("Standard")
  status      String   @default("Active")
  assignedTo  String?
  aiSummary   String?
  log         Json?
  items       Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User?    @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model SupportTicket {
  id        Int      @id @default(autoincrement())
  ticketId  String   @unique
  userId    Int?
  subject   String
  category  String   @default("Other")
  message   String
  status    String   @default("Open")
  priority  String   @default("Medium")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model Promotion {
  id          Int       @id @default(autoincrement())
  code        String    @unique
  type        String
  value       Float
  cap         Float?
  used        Int       @default(0)
  maxUsage    Int       @default(1000)
  status      String    @default("Active")
  expiresAt   DateTime?
  description String?
  createdAt   DateTime  @default(now())

  @@index([code])
  @@index([status])
}

model UserSubscription {
  id        Int       @id @default(autoincrement())
  userId    Int
  plan      String
  price     Float
  status    String    @default("Active")
  autoRenew Boolean   @default(true)
  startDate DateTime  @default(now())
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
}

model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int?
  endpoint  String   @unique
  keys      Json
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
}

model InventoryItem {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  name         String
  category     String
  stock        Float      @default(0)
  unit         String     @default("pcs")
  minStock     Float      @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RestaurantStaff {
  id           Int        @id @default(autoincrement())
  restaurantId Int
  name         String
  role         String     @default("Staff")
  phone        String?
  email        String?
  status       String     @default("Active")
  createdAt    DateTime   @default(now())
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId])
}

model RiderApplication {
  id        Int      @id @default(autoincrement())
  appId     String   @unique
  name      String
  phone     String?
  city      String?
  vehicle   String?
  status    String   @default("New")
  score     Int      @default(0)
  docs      Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RestaurantApplication {
  id        Int      @id @default(autoincrement())
  appId     String   @unique
  name      String
  ownerName String?
  phone     String?
  zone      String?
  category  String?
  plan      String?
  isPosOnly Boolean  @default(false)
  docs      Json?
  image     String?
  status    String   @default("Pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CmsAsset {
  id          Int      @id @default(autoincrement())
  title       String
  type        String
  region      String?
  description String?
  image       String?
  score       Int      @default(0)
  status      String   @default("Active")
  author      String?
  segment     String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model Badge {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  icon        String?
  description String?
  color       String?
  status      String      @default("active")
  createdAt   DateTime    @default(now())
  userBadges  UserBadge[]
}

model Refund {
  id             Int      @id @default(autoincrement())
  refundId       String   @unique
  orderId        String?
  restaurantName String?
  customerName   String?
  reason         String
  amount         Float
  riskScore      Int      @default(0)
  status         String   @default("Pending")
  paymentMethod  String?
  description    String?
  items          Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status])
}

model Favorite {
  id           Int      @id @default(autoincrement())
  userId       Int
  type         String
  restaurantId Int?
  menuItemId   Int?
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, restaurantId, menuItemId])
  @@index([userId])
}

model Address {
  id        Int      @id @default(autoincrement())
  userId    Int
  label     String   @default("Home")
  address   String
  landmark  String?
  lat       Float?
  lng       Float?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  body      String
  type      String   @default("info")
  url       String?
  isRead    Boolean  @default(false)
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
}

model OrderRating {
  id             Int      @id @default(autoincrement())
  orderId        Int      @unique
  userId         Int
  foodRating     Int      @default(5)
  deliveryRating Int?
  comment        String?
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model UserBadge {
  id       Int      @id @default(autoincrement())
  userId   Int
  badgeId  Int
  earnedAt DateTime @default(now())
  metadata Json?
  badge    Badge    @relation(fields: [badgeId], references: [id])
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model ReferralReward {
  id            Int       @id @default(autoincrement())
  referrerId    Int
  refereeName   String
  refereeEmail  String?
  pointsAwarded Int       @default(200)
  status        String    @default("pending")
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  referrer      User      @relation("ReferrerRewards", fields: [referrerId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([status])
}

model Hostel {
  id          Int                 @id @default(autoincrement())
  zoiId       String              @unique @default(cuid())
  name        String
  address     String?
  city        String?
  phone       String?
  email       String?
  type        String              @default("Mixed")
  totalRooms  Int                 @default(0)
  status      String              @default("Active")
  ownerId     Int?
  settings    Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  billing     HostelBilling[]
  complaints  HostelComplaint[]
  expenses    HostelExpense[]
  gatePasses  HostelGatePass[]
  laundry     HostelLaundry[]
  maintenance HostelMaintenance[]
  messOrders  HostelMessOrder[]
  notices     HostelNotice[]
  rooms       HostelRoom[]
  staff       HostelStaff[]
  visitors    HostelVisitor[]
  hostelers   Hosteler[]

  @@index([status])
}

model HostelRoom {
  id         Int        @id @default(autoincrement())
  zoiId      String     @unique @default(cuid())
  hostelId   Int
  roomNumber String
  floor      Int        @default(1)
  type       String     @default("Double")
  capacity   Int        @default(2)
  occupied   Int        @default(0)
  status     String     @default("Available")
  rent       Float      @default(0)
  amenities  Json?
  createdAt  DateTime   @default(now())
  hostel     Hostel     @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hostelers  Hosteler[]

  @@unique([hostelId, roomNumber])
  @@index([hostelId, status])
}

model Hosteler {
  id          Int               @id @default(autoincrement())
  zoiId       String            @unique @default(cuid())
  hostelId    Int
  roomId      Int?
  name        String
  email       String?
  phone       String
  parentPhone String?
  idType      String            @default("Aadhar")
  idNumber    String?
  joinDate    DateTime          @default(now())
  leaveDate   DateTime?
  status      String            @default("Active")
  plan        String            @default("Monthly")
  photoUrl    String?
  address     String?
  createdAt   DateTime          @default(now())
  billing     HostelBilling[]
  complaints  HostelComplaint[]
  gatePasses  HostelGatePass[]
  laundry     HostelLaundry[]
  messOrders  HostelMessOrder[]
  hostel      Hostel            @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  room        HostelRoom?       @relation(fields: [roomId], references: [id])

  @@index([hostelId, status])
}

model HostelBilling {
  id           Int       @id @default(autoincrement())
  zoiId        String    @unique @default(cuid())
  hostelId     Int
  hostelerId   Int
  month        String
  rentAmount   Float     @default(0)
  messAmount   Float     @default(0)
  laundryAmt   Float     @default(0)
  otherCharges Float     @default(0)
  discount     Float     @default(0)
  totalAmount  Float     @default(0)
  paidAmount   Float     @default(0)
  dueAmount    Float     @default(0)
  status       String    @default("Pending")
  dueDate      DateTime?
  paidDate     DateTime?
  paymentMode  String?
  receiptNo    String?
  notes        String?
  createdAt    DateTime  @default(now())
  hostel       Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hosteler     Hosteler  @relation(fields: [hostelerId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
  @@index([hostelerId])
}

model HostelMessOrder {
  id          Int       @id @default(autoincrement())
  zoiId       String    @unique @default(cuid())
  hostelId    Int
  hostelerId  Int?
  mealType    String    @default("Lunch")
  items       Json
  totalAmount Float     @default(0)
  status      String    @default("Pending")
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hosteler    Hosteler? @relation(fields: [hostelerId], references: [id])

  @@index([hostelId, date])
}

model HostelGatePass {
  id          Int       @id @default(autoincrement())
  zoiId       String    @unique @default(cuid())
  hostelId    Int
  hostelerId  Int
  purpose     String
  destination String?
  outTime     DateTime?
  expectedIn  DateTime?
  actualIn    DateTime?
  status      String    @default("Pending")
  approvedBy  String?
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hosteler    Hosteler  @relation(fields: [hostelerId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
  @@index([hostelerId])
}

model HostelComplaint {
  id         Int       @id @default(autoincrement())
  zoiId      String    @unique @default(cuid())
  hostelId   Int
  hostelerId Int?
  category   String    @default("General")
  subject    String
  message    String
  priority   String    @default("Medium")
  status     String    @default("Open")
  response   String?
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())
  hostel     Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hosteler   Hosteler? @relation(fields: [hostelerId], references: [id])

  @@index([hostelId, status])
}

model HostelMaintenance {
  id          Int       @id @default(autoincrement())
  zoiId       String    @unique @default(cuid())
  hostelId    Int
  roomId      Int?
  category    String    @default("Electrical")
  title       String
  description String?
  priority    String    @default("Medium")
  status      String    @default("Pending")
  assignedTo  String?
  cost        Float?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
}

model HostelExpense {
  id          Int      @id @default(autoincrement())
  zoiId       String   @unique @default(cuid())
  hostelId    Int
  category    String   @default("Maintenance")
  title       String
  amount      Float
  paidTo      String?
  paidBy      String?
  paymentMode String?
  receiptUrl  String?
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  hostel      Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, date])
}

model HostelStaff {
  id        Int      @id @default(autoincrement())
  zoiId     String   @unique @default(cuid())
  hostelId  Int
  name      String
  role      String   @default("Caretaker")
  phone     String?
  email     String?
  salary    Float?
  joinDate  DateTime @default(now())
  status    String   @default("Active")
  createdAt DateTime @default(now())
  hostel    Hostel   @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
}

model HostelNotice {
  id        Int       @id @default(autoincrement())
  zoiId     String    @unique @default(cuid())
  hostelId  Int
  title     String
  message   String
  category  String    @default("General")
  pinned    Boolean   @default(false)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  hostel    Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, createdAt])
}

model HostelVisitor {
  id          Int       @id @default(autoincrement())
  zoiId       String    @unique @default(cuid())
  hostelId    Int
  visitorName String
  phone       String?
  purpose     String?
  toMeetId    Int?
  inTime      DateTime  @default(now())
  outTime     DateTime?
  idType      String?
  idNumber    String?
  status      String    @default("In")
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)

  @@index([hostelId, createdAt])
}

model HostelLaundry {
  id          Int       @id @default(autoincrement())
  zoiId       String    @unique @default(cuid())
  hostelId    Int
  hostelerId  Int
  items       Json
  totalItems  Int       @default(0)
  charges     Float     @default(0)
  status      String    @default("Collected")
  pickupDate  DateTime  @default(now())
  deliverDate DateTime?
  createdAt   DateTime  @default(now())
  hostel      Hostel    @relation(fields: [hostelId], references: [id], onDelete: Cascade)
  hosteler    Hosteler  @relation(fields: [hostelerId], references: [id], onDelete: Cascade)

  @@index([hostelId, status])
  @@index([hostelerId])
}
